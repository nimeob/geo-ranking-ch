# .env.example — Environment variables template for geo-ranking-ch
# Copy to .env and fill in real values. Never commit .env.
#
# Issue: #833 (INFRA-DB-0.wp4)

# ---------------------------------------------------------------------------
# Local Dev DB (docker-compose.dev.yml)
# ---------------------------------------------------------------------------
POSTGRES_DB=georanking_dev
POSTGRES_USER=georanking
POSTGRES_PASSWORD=dev_only_change_me
POSTGRES_PORT=5432

# Full DSN used by application code and migration scripts
DATABASE_URL=postgresql://georanking:dev_only_change_me@localhost:5432/georanking_dev

# ---------------------------------------------------------------------------
# Staging / Production (filled by Secrets Manager / ECS secrets injection)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://<user>:<pass>@<rds-host>:5432/georanking

# ---------------------------------------------------------------------------
# AWS (for local scripts that need AWS access)
# ---------------------------------------------------------------------------
# AWS_REGION=eu-central-1
# AWS_PROFILE=your-profile

# ---------------------------------------------------------------------------
# BFF OIDC (BFF-0 / Issue #851)
# Leave BFF_OIDC_ISSUER unset to disable the BFF OIDC flow entirely.
# ---------------------------------------------------------------------------
# BFF_OIDC_ISSUER=https://cognito-idp.eu-central-1.amazonaws.com/eu-central-1_XXXXXX
# BFF_OIDC_CLIENT_ID=<cognito-app-client-id>
# BFF_OIDC_CLIENT_SECRET=          # leave empty for PKCE-only public clients
# BFF_OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
# BFF_OIDC_SCOPES=openid email profile
# BFF_OIDC_AUTH_ENDPOINT=          # optional override; default: {ISSUER}/oauth2/authorize
# BFF_OIDC_TOKEN_ENDPOINT=         # optional override; default: {ISSUER}/oauth2/token
# BFF_OIDC_NEXT_PARAM_ALLOW_SAME_ORIGIN=1   # 0 to disable ?next= redirect after login
# BFF_OIDC_LOGOUT_ENDPOINT=              # optional override; default: {ISSUER}/logout
# BFF_API_CALL_TIMEOUT_SECONDS=10        # timeout for bff_api_call downstream requests (wp3)
# BFF_PORTAL_API_BASE_URL=http://localhost:8080  # base URL for portal proxy forwarding (wp4)
# BFF_CSRF_HEADER_NAME=X-BFF-CSRF        # custom CSRF header name (wp4, default: X-BFF-CSRF)
# BFF_CSRF_HEADER_VALUE=1                # expected CSRF header value (wp4, default: 1)

# BFF Session cookie (BFF-0.wp1)
# BFF_SESSION_COOKIE_NAME=__Host-session
# BFF_SESSION_TTL_SECONDS=3600
# BFF_SESSION_SECURE_COOKIE=1      # set 0 for local http dev only
