# --- Basis ---
# Dev-Skeleton: Werte ggf. an reale Namen anpassen, sobald dev Ressourcen provisioniert sind.
project_name = "swisstopo"
environment  = "dev"
aws_region   = "eu-central-1"
owner        = "nico"
managed_by   = "openclaw"

# --- Sicherheitsmodus (Default): keine Ressourcen verwalten ---
# Dadurch ist ein "terraform plan" zunächst read-only/neutral.
lookup_existing_resources      = false
manage_ecs_cluster             = false
manage_ecr_repository          = false
manage_cloudwatch_log_group    = false
manage_cloudwatch_log_group_ui = false
manage_s3_bucket               = false

# --- Dev Network + Ingress Skeleton (INFRA-NET-0-dev) ---
# Default: vollständig deaktiviert (kein Create/Destroy in plan).
manage_dev_network     = false
manage_dev_ingress     = false
manage_dev_nat_gateway = false  # optional: NAT Egress für private Subnets

# --- Dev ECS Compute Skeleton ---
# Default: deaktiviert. Wird zusätzlich nur bei environment="dev" aktiv.
# Voraussetzung (aktuell): Dev Network/Subnets werden via manage_dev_network gemanagt.
manage_dev_ecs_compute = false

# --- Dev DB (INFRA-NET-0-dev) ---
# Default: deaktiviert. Guard: wirkt nur bei environment="dev" und nur wenn manage_dev_network=true.
manage_dev_db = false

# --- DB Secrets Wiring ---
# Wenn manage_dev_db=true: ARN wird automatisch aus aws_db_instance.dev_postgres gelesen.
# Wenn RDS in einem anderen TF-Workspace liegt (Cross-Workspace): ARN hier explizit eintragen.
# Format: arn:aws:secretsmanager:<region>:<account-id>:secret:<name>-<suffix>
# dev_db_master_user_secret_arn_override = ""

# Optional: Override DB Sizing/Naming
# dev_db_instance_identifier   = "swisstopo-dev-postgres"
# dev_db_instance_class        = "db.t4g.micro"
# dev_db_allocated_storage_gb  = 20
# dev_db_storage_type          = "gp3"
# dev_db_name                  = "swisstopo"
# dev_db_master_username       = "swisstopo"
# dev_db_ingress_source_security_group_ids = ["sg-0123456789abcdef0"]
# dev_db_engine_version        = ""   # "" => AWS Default
# dev_db_backup_retention_days = 7

# Optional: Override Container Image/Ports/Roles (Defaults sind bewusst "safe" / placeholder)
# dev_container_image = "<ACCOUNT>.dkr.ecr.<REGION>.amazonaws.com/<repo>:<tag>"
# dev_container_port  = 8080
# dev_task_execution_role_arn = "arn:aws:iam::<account-id>:role/<role>"
# dev_task_role_arn           = "arn:aws:iam::<account-id>:role/<role>"

dev_vpc_cidr = "10.80.0.0/16"

# Public Subnets (mind. 2 empfohlen, unterschiedliche AZs)
dev_public_subnet_cidrs = ["10.80.0.0/24", "10.80.1.0/24"]

# Private Subnets (NAT-Egress optional via manage_dev_nat_gateway=true)
dev_private_subnet_cidrs = ["10.80.10.0/24", "10.80.11.0/24"]

dev_alb_name = "swisstopo-dev-alb"

# HTTP 80 allowlist (nur relevant wenn manage_dev_ingress=true)
dev_alb_ingress_cidr_blocks = ["0.0.0.0/0"]

# --- Ziel-/Bestandsnamen (dev) ---
# Konvention: <project>-<env>(-<component>)
ecs_cluster_name               = "swisstopo-dev"
ecs_container_insights_enabled = false

ecr_repository_name          = "swisstopo-dev-api"
cloudwatch_log_group_name    = "/swisstopo/dev/ecs/api"
cloudwatch_log_group_ui_name = "/swisstopo/dev/ecs/ui"
cloudwatch_log_retention_days = 30

# Hinweis: Bucket-Name ist global eindeutig. Placeholder bis dev final ist.
# Beispiel-Pattern: swisstopo-dev-<account-id>
s3_bucket_name = "swisstopo-dev-523234426229"

existing_ecs_cluster_name             = "swisstopo-dev"
existing_ecr_repository_name         = "swisstopo-dev-api"
existing_cloudwatch_log_group_name    = "/swisstopo/dev/ecs/api"
existing_cloudwatch_log_group_ui_name = "/swisstopo/dev/ecs/ui"
existing_s3_bucket_name               = "swisstopo-dev-523234426229"

# --- Telegram Alerting ---
manage_telegram_alerting = false

# --- HTTP Health Probe ---
manage_health_probe = false

health_probe_ecs_cluster      = "swisstopo-dev"
health_probe_ecs_service      = "swisstopo-dev-api"
health_probe_port             = 8080
health_probe_path             = "/health"
health_probe_metric_namespace = "swisstopo/dev-api"

health_probe_lambda_name = "swisstopo-dev-health-probe"
health_probe_role_name   = "swisstopo-dev-health-probe-role"
health_probe_rule_name   = "swisstopo-dev-health-probe-schedule"
health_probe_alarm_name  = "swisstopo-dev-api-health-probe-fail"
health_probe_schedule_expression = "rate(5 minutes)"

aws_account_id   = "523234426229"
sns_topic_arn    = "arn:aws:sns:eu-central-1:523234426229:swisstopo-dev-alerts"
telegram_chat_id = ""  # z.B. "8614377280" — kein Secret, nur numerische ID

# --- Service URLs (Placeholder) ---
# Sobald Ingress/ALB live ist, api_base_url setzen (z. B. https://<alb-dns-name>)
api_base_url    = ""
api_health_path = "/health"
